{
  "name": "homelab-vm-provisioner-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build:app": "node ./node_modules/vite/bin/vite.js build",
    "build": "npm run build:app && npm run docs:build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "lint": "node ./node_modules/eslint/bin/eslint.js src test",
    "test": "npm run lint && node ./node_modules/vitest/vitest.mjs run",
    "coverage": "npm run lint && node ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "docs:build": "node scripts/build-docs.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "documentation": "^14.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.0.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
