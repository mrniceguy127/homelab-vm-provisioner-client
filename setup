#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source component library
source "$SCRIPT_DIR/scripts/lib.sh"

# Source .env
source_env "$SCRIPT_DIR/.env"

# Parse arguments
SKIP_NPM=false
SKIP_PLAYWRIGHT=false
SKIP_SYSTEM_PACKAGES=false

for arg in "$@"; do
    case "$arg" in
        --skip-npm) SKIP_NPM=true ;;
        --skip-playwright) SKIP_PLAYWRIGHT=true ;;
        --skip-system-packages) SKIP_SYSTEM_PACKAGES=true ;;
        --help)
            cat <<EOF
Usage: $0 [OPTIONS]

Setup the React client environment.

Options:
  --skip-npm               Skip npm install (for Docker builds)
  --skip-playwright        Skip Playwright installation
  --skip-system-packages   Skip system package installation
  --help                   Show this help message
EOF
            exit 0
            ;;
    esac
done

cd "$SCRIPT_DIR"

# Install system packages if not skipped
if [[ "$SKIP_SYSTEM_PACKAGES" == "false" ]]; then
    ensure_sudo_once "Installing system packages requires sudo."
    log "Installing Node.js"
    install_system_packages_nodejs
fi

log "Setting up client environment"

# Check for Node.js (required even if system packages were skipped)
if [[ "$SKIP_SYSTEM_PACKAGES" == "true" ]]; then
    require_cmd node
    require_cmd npm
    NODE_VERSION=$(node -v | cut -d. -f1 | tr -d 'v')
    [[ "$NODE_VERSION" -lt 18 ]] && error "Node.js 18+ required, found: $(node -v)" && exit 1
fi

if [[ "$SKIP_NPM" == "false" ]]; then
    log "Installing npm packages"
    npm install
fi

if [[ "$SKIP_PLAYWRIGHT" == "false" && "$SKIP_NPM" == "false" ]]; then
    if [[ -f "node_modules/@playwright/test/cli.js" ]]; then
        log "Installing Playwright Chromium"
        node node_modules/@playwright/test/cli.js install chromium
    fi
fi

log "Client setup complete"
