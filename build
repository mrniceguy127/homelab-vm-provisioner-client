#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIENT_DIR="$SCRIPT_DIR"

# Source component .env (parent vars inherited through execution sequence)
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Parse arguments
USE_DOCKER=false
for arg in "$@"; do
    case "$arg" in
        --docker)
            USE_DOCKER=true
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

if [[ "$USE_DOCKER" == "true" ]]; then
    log "Building client static files with Docker"

    # Build Docker image
    docker build -t homelab-vm-provisioner-client-builder "$CLIENT_DIR"

    # Create temporary container to extract build artifacts
    CONTAINER_ID=$(docker create homelab-vm-provisioner-client-builder)

    # Extract built files to dist/
    rm -rf "$CLIENT_DIR/dist"
    mkdir -p "$CLIENT_DIR/dist"
    docker cp "$CONTAINER_ID:/app/dist/." "$CLIENT_DIR/dist/"

    # Clean up container (image remains for caching)
    docker rm "$CONTAINER_ID"

    log "Client static files built from Docker to: $CLIENT_DIR/dist"
else
    log "Building client (app + docs)"
    npm --prefix "$CLIENT_DIR" run build
    
    log "Client built to: $CLIENT_DIR/dist"
fi
